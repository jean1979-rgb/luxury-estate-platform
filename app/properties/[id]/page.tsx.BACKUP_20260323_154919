            </h2>

            <div className="mt-6 text-white/70 leading-relaxed">
              <PropertyStory
                title={property.title}
                description={property.description}
              />
            </div>
          </div>

          {/* 360 EXPERIENCE */}
          <div>
            <p className="text-[10px] tracking-[0.4em] uppercase text-white/30">
              Experiencia inmersiva
            </p>
            <h2 className="mt-3 text-3xl font-light">
              Recorrido 360
            </h2>

            <div className="mt-6 rounded-[28px] overflow-hidden border border-white/10">
              <Viewer360 image={property.panoramaScenes[0]?.image} />
            </div>
          </div>

        </div>

        {/* DERECHA / STICKY */}
