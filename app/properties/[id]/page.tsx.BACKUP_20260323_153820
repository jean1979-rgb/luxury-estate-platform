                </p>
                <h2 className="mt-2 text-2xl font-light">La experiencia</h2>
              </div>
            </div>

            <PropertyStory
              title={property.title}
              description={property.description}
            />
          </div>

          <div className="rounded-[28px] border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <div className="mb-5">
              <p className="text-[11px] uppercase tracking-[0.35em] text-white/35">
                Recorrido
              </p>
              <h2 className="mt-2 text-2xl font-light">Visor 360</h2>
            </div>

            <div className="overflow-hidden rounded-[24px] border border-white/10">
              <Viewer360 image={property.panoramaScenes[0].image} />
