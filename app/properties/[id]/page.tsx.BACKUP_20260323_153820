  const property = properties.find((item) => item.id === id);

  if (!property) {
    notFound();
  }

  return (
    <main className="min-h-screen bg-[#0a0a0a] text-[#f5f1eb]">
      <section className="relative overflow-hidden border-b border-white/10">
        <img
          src={property.coverImage}
          alt={property.title}
          className="h-[72vh] w-full object-cover"
        />
        <div className="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-black/30 to-black/10" />

        <div className="absolute left-0 right-0 top-0 z-20 px-6 py-6 md:px-10">
          <Link
            href="/"
            className="inline-flex items-center gap-2 text-sm text-white/75 transition hover:text-white"
          >
            ← Volver a colección
          </Link>
        </div>

        <div className="absolute bottom-0 left-0 right-0 z-20 px-6 pb-10 md:px-10 md:pb-14">
          <div className="mx-auto max-w-7xl">
            <p className="text-[11px] uppercase tracking-[0.35em] text-[#c6bfb3]">
              Residencia curada
            </p>

            <h1 className="mt-4 max-w-4xl text-4xl font-light leading-tight md:text-6xl">
              {property.title}
            </h1>

            <p className="mt-4 max-w-2xl text-base text-[#e7dfd4] md:text-lg">
              {property.tagline}
            </p>

            <div className="mt-6 flex flex-wrap items-center gap-3 text-sm text-white/70">
              <span className="rounded-full border border-white/15 px-4 py-2">
                {property.location}
              </span>
              <span className="rounded-full border border-white/15 px-4 py-2">
                {property.price}
              </span>
            </div>
          </div>
        </div>
      </section>

      <section className="mx-auto grid max-w-7xl gap-8 px-6 py-10 md:grid-cols-[1.3fr_0.7fr] md:px-10">
        <div className="space-y-8">
          <div className="rounded-[28px] border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <Gallery images={property.gallery} />
          </div>

          <div className="rounded-[28px] border border-white/10 bg-white/[0.03] p-6 md:p-8">
            <div className="mb-5 flex items-center justify-between gap-4">
              <div>
