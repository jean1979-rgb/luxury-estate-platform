    <main className="min-h-screen bg-[#0a0a0a] text-[#f5f1eb]">
      <section className="border-b border-white/10 px-6 py-6 md:px-10">
        <div className="mx-auto flex max-w-7xl items-center justify-between">
          <div>
            <p className="text-[10px] uppercase tracking-[0.35em] text-[#b8afa3]">
