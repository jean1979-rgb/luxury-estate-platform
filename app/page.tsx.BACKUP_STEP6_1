            </p>
            <h1 className="mt-2 text-2xl font-light tracking-[0.08em] md:text-3xl">
              LUXE Estates
            </h1>
          </div>
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-6 py-8 md:px-10 md:py-10">
        <Link
          href={`/properties/${featured.id}`}
          className="group relative block overflow-hidden rounded-[28px] border border-white/10"
        >
          <img
            src={featured.coverImage}
            className="h-[520px] w-full object-cover transition duration-700 group-hover:scale-[1.03]"
          />
          <div className="absolute inset-0 bg-black/30" />

          <div className="absolute bottom-0 p-8">
            <h2 className="text-4xl font-light">{featured.title}</h2>
            <p className="mt-2 text-[#e7dfd4]">{featured.tagline}</p>
          </div>
        </Link>

        <div className="mt-10 grid gap-6 md:grid-cols-3">
          {secondary.map((property) => (
