type Props = {
  images: string[];
};

export default function Gallery({ images }: Props) {
  return (
    <section>
      <div className="mb-5 flex items-center justify-between">
        <div>
          <p className="text-[10px] uppercase tracking-[0.35em] text-[#d6c3a1]">
            Visual Gallery
          </p>
          <h3 className="mt-2 text-2xl font-light md:text-3xl">
            Una narrativa visual cuidada
          </h3>
        </div>
      </div>

      <div className="grid gap-4 md:grid-cols-12">
        {images.map((img, i) => {
          const span =
            i === 0 ? "md:col-span-7" : i === 1 ? "md:col-span-5" : "md:col-span-6";

          return (
            <div
              key={i}
              className={`overflow-hidden rounded-[24px] border border-white/10 ${span}`}
            >
              <img
                src={img}
                alt={`Gallery image ${i + 1}`}
                className="h-[260px] w-full object-cover transition duration-700 hover:scale-[1.04] md:h-[320px]"
              />
            </div>
          );
        })}
      </div>
    </section>
  );
}
