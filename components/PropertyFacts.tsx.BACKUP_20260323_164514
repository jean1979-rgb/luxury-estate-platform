type Props = {
  price: string;
  bedrooms: number;
  bathrooms: number;
  area: string;
  location: string;
};

export default function PropertyFacts({
  price,
  bedrooms,
  bathrooms,
  area,
  location,
}: Props) {
  const items = [
    { label: "Precio", value: price },
    { label: "Recámaras", value: String(bedrooms) },
    { label: "Baños", value: String(bathrooms) },
    { label: "Superficie", value: area },
    { label: "Ubicación", value: location },
  ];

  return (
    <div className="rounded-[24px] border border-white/10 bg-[#121212] p-6 md:p-7">
      <p className="text-[10px] uppercase tracking-[0.35em] text-[#b8afa3]">
        Property Facts
      </p>

      <div className="mt-5 space-y-4">
        {items.map((item) => (
          <div
            key={item.label}
            className="flex items-start justify-between gap-4 border-b border-white/8 pb-4 text-sm"
          >
            <span className="text-[#b8afa3]">{item.label}</span>
            <span className="text-right text-[#f5f1eb]">{item.value}</span>
          </div>
        ))}
      </div>
    </div>
  );
}
